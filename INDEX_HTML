!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>¡El Gran Salto del Conejito!</title>
<style>
    body {
        font-family: 'Comic Sans MS', cursive, sans-serif; /* Fuente divertida */
        text-align: center;
        background-color: #f0f8ff; /* Azul cielo suave */
    }

    h1 {
        color: #e91e63; /* Rosa fuerte */
    }

    #game-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        margin-top: 20px;
    }

    #grid {
        display: grid;
        grid-template-columns: repeat(4, 80px); /* 4 columnas de 80px */
        grid-template-rows: repeat(4, 80px);    /* 4 filas de 80px */
        gap: 5px; /* Espacio entre cuadros */
        border: 4px solid #4caf50; /* Borde verde césped */
        background-color: #fff;
    }

    .cell {
        border: 2px solid #ddd;
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 2em; /* Tamaño grande para los emojis/iconos */
        border-radius: 8px;
    }

    .conejito {
        background-color: #ffff00; /* Fondo amarillo para el conejito */
    }

    .amigo {
        color: #9c27b0; /* Color para los amigos */
    }

    .premio {
        color: #ff5722; /* Color para el premio */
    }

    #controls {
        margin-top: 20px;
    }

    button {
        font-size: 1.5em;
        padding: 10px 20px;
        margin: 5px;
        cursor: pointer;
        border: none;
        border-radius: 8px;
        color: white;
    }

    #up { background-color: #2196f3; } /* Azul */
    #down { background-color: #4caf50; } /* Verde */
    #left { background-color: #ff9800; } /* Naranja */
    #right { background-color: #ffeb3b; color: black;} /* Amarillo */

    #message {
        margin-top: 20px;
        font-size: 1.2em;
        font-weight: bold;
        color: #333;
    }
</style>
</head>
<body>

    <h1>🐰 ¡Ayuda al Conejito a Saltar! 🥕</h1>
    
    <div id="game-container">
        <div id="grid">
            </div>

        <div id="controls">
            <button id="up">⬆️ Arriba</button><br>
            <button id="left">⬅️ Izquierda</button>
            <button id="down">⬇️ Abajo</button>
            <button id="right">➡️ Derecha</button>
        </div>

        <p id="message">¡Usa los botones para mover al Conejito!</p>
    </div>

<script>
    const gridSize = 4;
    let rabbitPosition = { row: 0, col: 0 };
    let items = [
        { row: 1, col: 2, type: '🐻' }, // Osito
        { row: 2, col: 0, type: '🐱' }, // Gatito
        { row: 3, col: 3, type: '🥕' }, // Zanahoria (premio)
    ];

    const grid = document.getElementById('grid');
    const message = document.getElementById('message');

    function createGrid() {
        grid.innerHTML = '';
        for (let r = 0; r < gridSize; r++) {
            for (let c = 0; c < gridSize; c++) {
                const cell = document.createElement('div');
                cell.className = 'cell';
                
                // Colocar al conejito
                if (r === rabbitPosition.row && c === rabbitPosition.col) {
                    cell.innerText = '🐰';
                    cell.classList.add('conejito');
                } else {
                    // Colocar amigos o premio si coinciden
                    const item = items.find(i => i.row === r && i.col === c);
                    if (item) {
                        cell.innerText = item.type;
                        if (item.type === '🥕') {
                            cell.classList.add('premio');
                        } else {
                            cell.classList.add('amigo');
                        }
                    }
                }
                
                grid.appendChild(cell);
            }
        }
    }

    function moveRabbit(rowChange, colChange) {
        let newRow = rabbitPosition.row + rowChange;
        let newCol = rabbitPosition.col + colChange;

        // Verificar límites de la cuadrícula
        if (newRow >= 0 && newRow < gridSize && newCol >= 0 && newCol < gridSize) {
            rabbitPosition.row = newRow;
            rabbitPosition.col = newCol;
            checkInteraction();
            createGrid(); // Redibujar la cuadrícula
        }
    }

    function checkInteraction() {
        // Buscar si el conejito está en la misma celda que un item
        const itemIdx = items.findIndex(i => i.row === rabbitPosition.row && i.col === rabbitPosition.col);
        
        if (itemIdx !== -1) {
            const itemText = items[itemIdx].type;
            if (itemText === '🥕') {
                message.innerText = "¡DELICIOSO! ¡Conejito encontró la Zanahoria! 🥕 ¡Eres genial!";
                message.style.color = '#ff5722';
            } else {
                message.innerText = `¡Hola ${itemText}! ¡Conejito saludó a su amigo!`;
                message.style.color = '#9c27b0';
            }
        } else {
            message.innerText = "¡Sigue saltando!";
            message.style.color = '#333';
        }
    }

    // Configurar botones
    document.getElementById('up').addEventListener('click', () => moveRabbit(-1, 0));
    document.getElementById('down').addEventListener('click', () => moveRabbit(1, 0));
    document.getElementById('left').addEventListener('click', () => moveRabbit(0, -1));
    document.getElementById('right').addEventListener('click', () => moveRabbit(0, 1));

    createGrid(); // Inicializar el juego

</script>
</body>
</html>
